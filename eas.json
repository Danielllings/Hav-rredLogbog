{
  "cli": {
    "version": ">= 6.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "postInstall": "bash eas-build-post-install.sh"
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "extends": "base"
    },
    "preview": {
      "distribution": "internal",
      "extends": "base"
    },
    "production": {
      "autoIncrement": true,
      "extends": "base"
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./play-service-account.json",
        "track": "internal"
      }
    }
  }
}
